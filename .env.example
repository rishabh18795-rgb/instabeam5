# ──────────────────────────────────────────────────────────
# InstaBeam — environment variables
# Copy this file to .env.local for local development, and set
# the same keys in Vercel → Project → Settings → Environment
# Variables for Preview/Production.
# ──────────────────────────────────────────────────────────

# Resend (https://resend.com) — required for the /contact enquiry
# form to actually send emails. Without this, submissions are
# validated but return a 503 asking the visitor to use WhatsApp
# instead, so the site never fails silently.
RESEND_API_KEY=

# Where enquiry notifications are delivered. Defaults to
# hello@instabeam.co if unset.
ENQUIRY_NOTIFY_EMAIL=hello@instabeam.co

# The "from" address used for outbound mail. Must be on a domain
# verified in your Resend account.
ENQUIRY_FROM_EMAIL="InstaBeam <enquiries@instabeam.site>"

# ──────────────────────────────────────────────────────────
# Phase 3+ (Admin Portal / database) — not required yet, added
# here so the shape is documented ahead of time.
# ──────────────────────────────────────────────────────────

# Supabase / PostgreSQL
# DATABASE_URL=
# DIRECT_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Admin auth
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000

# Cloudinary (media library)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
