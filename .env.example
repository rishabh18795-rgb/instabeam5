# ──────────────────────────────────────────────────────────
# InstaBeam — environment variables
# Copy this file to .env.local for local development, and set
# the same keys in Vercel → Project → Settings → Environment
# Variables for Preview/Production.
# ──────────────────────────────────────────────────────────

# Resend (https://resend.com) — required for every form on the site
# (contact page, homepage free-audit form, blog newsletter) to send
# email notifications. Leads are always captured in Supabase regardless
# of whether this is set, so a submission is never silently lost.
RESEND_API_KEY=

# Where enquiry notifications are delivered. Defaults to
# help.instabeam@gmail.com if unset.
ENQUIRY_NOTIFY_EMAIL=help.instabeam@gmail.com

# The "from" address used for outbound mail. Must be on a domain
# verified in your Resend account.
ENQUIRY_FROM_EMAIL="InstaBeam <enquiries@instabeam.site>"

# ──────────────────────────────────────────────────────────
# CRM (Supabase) — every form submission is inserted as a row in the
# `leads` table (see supabase/migrations/0001_create_leads.sql) and
# surfaced in the /admin dashboard.
# ──────────────────────────────────────────────────────────

# Project URL, e.g. https://xxxxx.supabase.co
SUPABASE_URL=

# Service role key (Project Settings → API). Server-only — never expose
# this to the client / never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────
# Admin panel (/admin) — simple password + signed-cookie session, no
# external auth provider required.
# ──────────────────────────────────────────────────────────

# Password required to sign in to /admin.
ADMIN_PASSWORD=

# Random secret used to sign the admin session cookie. Generate with:
# openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ──────────────────────────────────────────────────────────
# Google Sheets — the enquiry form (contact page + homepage free-audit
# form) also appends a row to a Google Sheet via an Apps Script Web App.
# See google-apps-script/README.md for the one-time deploy step.
# ──────────────────────────────────────────────────────────

# The deployed Apps Script Web App URL (ends in /exec).
GOOGLE_SHEETS_WEBHOOK_URL=

# Shared secret the webhook checks against — must match the
# SHARED_SECRET script property set in step 3 of the Apps Script deploy.
GOOGLE_SHEETS_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────
# Phase 2+ (not required yet, added so the shape is documented ahead of
# time)
# ──────────────────────────────────────────────────────────

# Cloudinary (media library)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
